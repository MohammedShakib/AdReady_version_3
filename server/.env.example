GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_URL=
GEMINI_IMAGE_FALLBACK_URL=
GEMINI_IMAGE_MIME=image/png

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_URL=
OPENAI_IMAGE_MODEL=gpt-image-1-mini

REMOVE_BG_API_KEY=

# ==========================================
#        DATABASE CONFIGURATION (POSTGRES)
# ==========================================
# Optional: preferred for Supabase.
# Example: postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=adreadyDB
PGSSLMODE=false
# Set false to stop runtime CREATE TABLE / schema bootstrap queries.
DB_AUTO_DDL=true
JWT_SECRET=
JWT_EXPIRES_IN=7d
INTERNAL_API_KEY=
# Optional but recommended. Used to encrypt/decrypt stored project API keys.
# Falls back to INTERNAL_API_KEY/JWT_SECRET when not set.
PROJECT_API_KEY_ENCRYPTION_SECRET=
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_SADMIN_PASSWORD=
ALLOW_DEV_AUTH_BYPASS=false
DEV_AUTH_BYPASS_PASSWORD=admin
DEV_AUTH_BYPASS_TOKEN=dev-auth-bypass

# ==========================================
#        SOCIAL MEDIA - TELEGRAM
# ==========================================
TELEGRAM_BOT_TOKEN=
BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MODE=polling
PUBLIC_SERVER_URL=
TELEGRAM_WEBHOOK_PATH=/webhook
TELEGRAM_FILL_ANALYZE_PROVIDER=gemini
TELEGRAM_ADVANCE_FAST_FILL=true
TELEGRAM_AI_FILL_LOCK_MS=120000

# ==========================================
#        PAYMENT INTEGRATIONS
# ==========================================
PAYMENT_REDIRECT_URL=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLIENT_BASE_URL=
TELEGRAM_TOPUP_CREDITS=50
TELEGRAM_TOPUP_PRICE_USD=15

# ==========================================
#        EMAIL (SMTP)
# ==========================================
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_FROM="AdReady <no-reply@example.com>"
